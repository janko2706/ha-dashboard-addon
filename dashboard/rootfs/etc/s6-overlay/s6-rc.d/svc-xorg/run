#!/command/with-contenv sh
# vt1 is mandatory — Xorg fails with "Cannot open virtual console" inside Docker without it
echo "[svc-xorg] Starting Xorg"
echo "[svc-xorg] Checking display devices"
ls -l /dev/fb* /dev/tty0 /dev/tty1 2>&1 || true

# Log framebuffer resolution so we can see what the kernel negotiated with the display.
echo "[svc-xorg] Framebuffer state:"
for fb in /dev/fb0 /dev/fb1; do
    [ -e "$fb" ] && fbset -fb "$fb" -i 2>&1 || true
done

# Attempt to force /dev/fb0 to 1920x1080 16-bit before Xorg attaches to it.
# On Pi 4 with KMS this may fail silently — if so the GUARANTEED fix is to add
# the following three lines to /boot/firmware/config.txt and reboot the Pi:
#   hdmi_force_hotplug=1
#   hdmi_group=1
#   hdmi_mode=16
fbset -fb /dev/fb0 -g 1920 1080 1920 1080 16 2>/dev/null \
    && echo "[svc-xorg] Forced /dev/fb0 to 1920x1080x16" \
    || echo "[svc-xorg] fbset could not resize /dev/fb0 — see /boot/firmware/config.txt note above"

# Hide the underlying Linux console cursor before Xorg starts. With -sharevts
# the console can remain visible around KMS framebuffer margins.
printf '\033[?25l\033[2J\033[H' >/dev/tty1 2>/dev/null || true
printf '\033[?25l\033[2J\033[H' >/dev/tty0 2>/dev/null || true

Xorg :0 \
    -config /etc/X11/xorg.conf \
    -nolisten tcp \
    -s 0 \
    -dpms \
    -sharevts \
    vt1 \
    2>&1

STATUS=$?

echo "[svc-xorg] Xorg exited with status $STATUS"
echo "[svc-xorg] Dumping last 200 lines of /var/log/Xorg.0.log"
tail -n 200 /var/log/Xorg.0.log 2>/dev/null || echo "[svc-xorg] No /var/log/Xorg.0.log found"

echo "[svc-xorg] Sleeping after Xorg failure to avoid flooding the add-on log"
sleep 3600

exit "$STATUS"
